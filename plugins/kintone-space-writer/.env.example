# kintone Space Writer secrets example.
# Copy this file to .env in an article workspace.
# Put target aliases and Space/thread IDs in kintone-targets.yaml.

# Optional: default target alias from kintone-targets.yaml.
KINTONE_TARGET=test-news

# Passwords referenced by passwordEnv in kintone-targets.yaml:
# - test-news uses KINTONE_TEST_PASSWORD
# - company-news/company-notice use KINTONE_ENV1_PASSWORD
# - branch-news uses KINTONE_ENV2_PASSWORD
KINTONE_TEST_PASSWORD=
KINTONE_ENV1_PASSWORD=
KINTONE_ENV2_PASSWORD=
