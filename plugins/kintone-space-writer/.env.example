# Required: kintone environment and login.
KINTONE_BASE_URL=https://example.cybozu.com
KINTONE_USERNAME=
KINTONE_PASSWORD=

# Required: existing Space thread target.
KINTONE_SPACE_ID=
KINTONE_THREAD_ID=

# Optional: set only for guest-space API paths.
KINTONE_GUEST_SPACE_ID=

# Optional: attached image display width for comment files, 100 to 750.
KINTONE_IMAGE_WIDTH=600

# Optional: set only if the kintone environment also requires cybozu Basic Auth.
KINTONE_BASIC_AUTH_USERNAME=
KINTONE_BASIC_AUTH_PASSWORD=
