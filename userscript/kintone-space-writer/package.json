{
  "name": "kintone-space-writer-userscript",
  "version": "0.2.1",
  "private": true,
  "description": "Store userscript for injecting Ready rich articles into kintone Space threads",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "vite --mode development --host 127.0.0.1",
    "build": "tsc --noEmit && vite build --mode production",
    "build:dev": "tsc --noEmit && vite build --mode development"
  },
  "devDependencies": {
    "@types/node": "^20.19.1",
    "@types/tampermonkey": "^4.0.5",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vite-plugin-monkey": "5.0.0"
  }
}
